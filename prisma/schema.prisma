generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  SENT
  REPLIED
  INTERESTED
  MEETING
  PROPOSAL
  CLIENT
  LOST
}

enum UserRole {
  ADMIN
  SELLER
  FINANCE
}

enum DocumentKind {
  PROPOSAL
  CONTRACT
  QUOTE
}

enum DocumentStatus {
  DRAFT
  GENERATED
  SENT
  SIGNED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
  BANK_TRANSFER
  CASH
}

enum ExportFormat {
  XLSX
  CSV
}

enum ExportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum SearchJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  messages MessageTemplate[]
  searches SearchHistory[]
  searchJobs SearchJob[]
  assignedLeads Lead[] @relation("LeadOwner")
  sales Sale[]
  auditLogs AuditLog[]
  logoAssets LogoAsset[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  state     String   @default("MG")
  region    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]

  @@unique([name, state])
}

model Lead {
  id           String     @id @default(cuid())
  company      String
  phone        String?
  address      String?
  cityName     String
  state        String
  website      String?
  instagram    String?
  googleMaps   String?
  rating       Float?
  reviewCount  Int?
  latitude     Float?
  longitude    Float?
  hasWhatsApp  Boolean    @default(false)
  status       LeadStatus @default(NEW)
  source       String     @default("APIFY_GOOGLE_MAPS")
  rawPayload   Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cityId     String?
  city       City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  ownerId    String?
  owner      User?     @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  analyses  LeadAnalysis[]
  followUps FollowUp[]
  documents ProposalDocument[]
  sales     Sale[]
  auditLogs AuditLog[]

  @@index([cityName, state])
  @@index([status])
  @@index([hasWhatsApp])
  @@index([createdAt])
  @@index([categoryId])
  @@index([ownerId])
  @@unique([company, phone, cityName])
}

model LeadAnalysis {
  id               String   @id @default(cuid())
  leadId           String
  potentialScore   Int
  closeProbability Int
  grade            String
  stars            Int
  reasons          Json
  opportunities    Json
  googleMapsScore  Int
  siteScore        Int
  instagramScore   Int
  siteAudit        Json?
  instagramAudit   Json?
  generatedMessage String   @db.Text
  provider         String   @default("ORBIT_RULE_ENGINE")
  createdAt        DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([potentialScore])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String   @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  category    String?
  city        String?
  status      String   @default("DRAFT")
  totalLeads  Int      @default(0)
  sentCount   Int      @default(0)
  replyCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FollowUp {
  id          String   @id @default(cuid())
  leadId      String
  title       String
  dueAt       DateTime
  completedAt DateTime?
  cadenceDays Int
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([dueAt])
}

model AutomationRule {
  id        String   @id @default(cuid())
  name      String
  trigger   String
  action    String
  active    Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trigger])
  @@index([active])
}

model ProposalDocument {
  id        String         @id @default(cuid())
  leadId    String
  kind      DocumentKind
  status    DocumentStatus @default(DRAFT)
  title     String
  value     Decimal?       @db.Decimal(12, 2)
  deadline  String?
  services  Json?
  content   Json
  fileUrl   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([kind])
}

model Sale {
  id            String        @id @default(cuid())
  leadId        String
  userId        String?
  value         Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  commission    Decimal?      @db.Decimal(12, 2)
  monthlyRevenue Decimal?     @db.Decimal(12, 2)
  profit        Decimal?      @db.Decimal(12, 2)
  closedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([closedAt])
}

model ExportJob {
  id        String       @id @default(cuid())
  format    ExportFormat
  status    ExportStatus @default(PENDING)
  fileName  String?
  filters   Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model SearchJob {
  id             String          @id @default(cuid())
  status         SearchJobStatus @default(PENDING)
  state          String
  city           String
  category       String
  maxResults     Int
  minRating      Float?
  minReviews     Int?
  filters        Json
  progress       Int             @default(0)
  message        String          @default("Na fila")
  resultCount    Int             @default(0)
  duplicateCount Int             @default(0)
  error          String?         @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SearchHistory {
  id            String   @id @default(cuid())
  state         String
  city          String
  category      String
  maxResults    Int
  minRating     Float?
  minReviews    Int?
  filters       Json?
  leadsFound    Int      @default(0)
  duplicates    Int      @default(0)
  createdAt     DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AppSettings {
  id             String   @id @default(cuid())
  companyName    String   @default("Orbit")
  logoUrl        String?
  logoStorageKey String?
  apifyToken     String?  @db.Text
  openAiApiKey   String?  @db.Text
  smtpHost       String?
  smtpUser       String?
  smtpPassword   String?  @db.Text
  databaseNote   String?
  defaultMessage String?  @db.Text
  theme          String   @default("light")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LogoAsset {
  id          String   @id @default(cuid())
  fileName    String
  mimeType    String
  size        Int
  provider    String
  storageKey  String?
  publicUrl   String
  createdAt   DateTime @default(now())

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([createdAt])
}
